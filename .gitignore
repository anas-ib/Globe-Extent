# See https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# ── Build output ──────────────────────────────────────────────────────────────
dist/
tmp/
out-tsc/
*.tsbuildinfo
.expo/
.expo-shared/

# ── Dependencies ──────────────────────────────────────────────────────────────
node_modules/

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-error.log*
testem.log
/libpeerconnection.log

# ── IDEs & editors ───────────────────────────────────────────────────────────
/.idea
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.cursor/rules/nx-rules.mdc
.github/instructions/nx.instructions.md

# ── OS ───────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.sass-cache/
/connect.lock
/coverage
/typings

# ── Replit platform (not project source) ─────────────────────────────────────
.cache/
.local/
.agents/

# ── Uploaded / temporary asset files ─────────────────────────────────────────
# Raw uploads from Replit chat (design briefs, pasted docs, source images)
attached_assets/Pasted--*.txt
attached_assets/image_*.png
attached_assets/image_*.jpg
